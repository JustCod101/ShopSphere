# 持久化数据卷（运行期生成，勿入库）
/data/
# 容器服务日志挂载目录（运行期生成）
/logs/

# 真实密钥（仅 .env.example 入库）
.env

# 构建产物
target/
*.class

# Claude Code 本地设置（用户本机权限，勿入库）
.claude/settings.local.json

# 密钥兜底：禁止任何模块目录下入库 PEM（公钥 docs/nacos/*.pem 例外，见下行白名单）
*.pem
!docs/nacos/*.pem

# IDE / OS
.idea/
*.iml
.DS_Store

# Python（推荐服务）
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
