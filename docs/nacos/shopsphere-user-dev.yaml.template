# Nacos dataId: shopsphere-user-dev.yaml
# namespace: dev   group: DEFAULT_GROUP
#
# 【机密配置】此模板仅作字段示意，**真实 ENC(...) 不入仓库**；
# 部署前用 jasypt-maven-plugin:encrypt-value 加密后直接粘贴到 Nacos console。
#
# 加密示例：
#   export JASYPT_ENCRYPTOR_PASSWORD=$(grep '^JASYPT_ENCRYPTOR_PASSWORD=' .env | cut -d= -f2-)
#   mvn -q com.github.ulisesbocchio:jasypt-maven-plugin:3.0.5:encrypt-value \
#       -Djasypt.encryptor.password="$JASYPT_ENCRYPTOR_PASSWORD" \
#       -Djasypt.plugin.value="$(tr -d '\n' < data/jwt/jwt-private-key.pem)"
#
# 输出形如 ENC(xxxBase64xxx==)，整体复制到 jwt.private-key 字段。

jwt:
  # 完整 PEM 文本（含 BEGIN/END 行）经 Jasypt 加密后单行 ENC(...)；运行时透明解密为 PEM
  private-key: ENC(REPLACE_ME_WITH_JASYPT_ENCRYPTED_PEM)

spring:
  datasource:
    url: jdbc:mysql://${MYSQL_HOST:localhost}:3306/shopsphere_user?useSSL=false&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true
    username: shopsphere
    password: ENC(REPLACE_ME_WITH_JASYPT_ENCRYPTED_DB_PASSWORD)
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2
      connection-timeout: 5000

  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: 6379
      # 若 Redis 未启用密码，删除此行；启用则填 ENC(...)
      # password: ENC(REPLACE_ME_WITH_JASYPT_ENCRYPTED_REDIS_PASSWORD)
      timeout: 3000ms
      lettuce:
        pool:
          max-active: 8
          max-idle: 8
          min-idle: 0

  # T1.4 行为埋点 MQ（user.behavior 轻量等级，contract §8）
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: ${RABBITMQ_PORT:5672}
    username: ${RABBITMQ_USER:guest}
    password: ENC(REPLACE_ME_WITH_JASYPT_ENCRYPTED_RABBIT_PASSWORD)
    virtual-host: shopsphere
    publisher-confirm-type: correlated   # Spring AMQP 3.1 小写枚举
    publisher-returns: true
    connection-timeout: 5000ms
    template:
      mandatory: true                     # 与 publisher-returns 配套；无队列绑定即 ReturnCallback
      retry:
        enabled: false                    # 轻量场景禁用模板内置重试
    # T3.4 订单事件消费者（q.points / q.notify）。手动 ack：消费者内显式 ack/nack 决策，
    # 不依赖容器自动重试（避免约束所禁的「retry 失控」）。
    listener:
      simple:
        acknowledge-mode: manual          # PointsConsumer / NotificationConsumer 手动 ack
        prefetch: 20                      # 每消费者未 ack 消息上限
        default-requeue-rejected: false   # 兜底：未显式处理的拒绝不无限 requeue
        retry:
          enabled: false                  # 重试由消费者内 Redis 计数显式控制
