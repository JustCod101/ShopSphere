# 复制为 .env 后使用：cp .env.example .env
# §10 敏感配置：所有口令经此注入，docker-compose 用 ${VAR} 引用，仓库零硬编码

# MySQL root 口令（Nacos / Seata / 各业务服务共用）
MYSQL_ROOT_PASSWORD=root123

# RabbitMQ 管理员
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# Jasypt 解密口令：业务服务用于解密 Nacos 中加密配置（§10）
# infra 本身不消费，预置占位，业务服务 Phase 启用时复用同一 .env
JASYPT_ENCRYPTOR_PASSWORD=please-change-me

# 生产环境另需开启（dev 默认关闭，见 README-infra.md）：
# REDIS_PASSWORD=
