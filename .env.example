# 复制为 .env 后使用:cp .env.example .env
# §10 敏感配置:所有口令经此注入,docker-compose 用 ${VAR} 引用,仓库零硬编码

# ============================================================
# 基础设施口令
# ============================================================

# MySQL root(Nacos / Seata / 各业务服务共用)
MYSQL_ROOT_PASSWORD=root123

# RabbitMQ 管理员
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# ============================================================
# 业务服务敏感配置(§10)
# ============================================================

# Jasypt 解密口令:业务服务用于解密 Nacos 中加密配置
# infra 不消费,业务服务启用时复用同一 .env
JASYPT_ENCRYPTOR_PASSWORD=please-change-me

# ============================================================
# 端口映射(宿主机 → 容器);容器内端口契约见 docs/api-contracts.md §5
# ============================================================

# 业务
GATEWAY_PORT=8080
USER_PORT=8081
PRODUCT_PORT=8082
ORDER_PORT=8083
RECO_PORT=8000

# 基础设施
MYSQL_PORT=3306
NACOS_PORT=8848
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
SEATA_PORT=8091
SEATA_CONSOLE_PORT=7091
SENTINEL_PORT=8858

# 监控(T5.3)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ============================================================
# Profile 控制(docker compose)
# ============================================================
# 默认全栈(infra + Java + Python)
# 仅 infra:覆盖为空 → COMPOSE_PROFILES= docker compose up
# 仅 infra+Java:COMPOSE_PROFILES=java docker compose up
# 仅 infra+Python:COMPOSE_PROFILES=python docker compose up
COMPOSE_PROFILES=java,python

# ============================================================
# Python 推荐服务:Nacos 注册 IP(可选)
# ============================================================
# 容器内默认:socket 解析容器主机名(compose 网络 DNS 可达,推荐留空)
# 开发期 host 上跑 Python + 容器内跑 Gateway:export NACOS_REGISTER_IP=host.docker.internal
# CI / 生产 K8s:不需要设(docker DNS / pod IP 自动)
# NACOS_REGISTER_IP=

# ============================================================
# 生产环境追加(dev 默认关闭)
# ============================================================
# Redis 开密码:redis service command 追加 --requirepass ${REDIS_PASSWORD}
# REDIS_PASSWORD=
